extends layout

block title
  | #{titulo}

block content
  style.
    th.sortable { cursor: pointer; user-select: none; }
    th.sortable:hover { background-color: #343a40; opacity: 0.85; }
    th.sortable .sort-icon { font-size: 0.75rem; margin-left: 4px; opacity: 0.5; }
    th.sortable.asc .sort-icon::after { content: '▲'; opacity: 1; }
    th.sortable.desc .sort-icon::after { content: '▼'; opacity: 1; }
    th.sortable:not(.asc):not(.desc) .sort-icon::after { content: '⇅'; }

  div.container.mt-4
    div.d-flex.justify-content-between.align-items-center.mb-4
      h1= titulo
      div.d-flex.gap-2
        a.btn.btn-primary(href="/clientes/nuevo-cliente") 
          i.bi.bi-plus-lg.me-2(aria-hidden="true")
          | Nuevo Cliente

    input.form-control.mb-3#buscadorClientes(type="text", placeholder="Buscar por nombre, email...")

    div.table-responsive
      table.table.table-hover.shadow-sm#tablaClientes
        thead.table-dark
          tr
            th.sortable(data-col="0") ID #[span.sort-icon]
            th.sortable(data-col="1") Nombre / Razón Social #[span.sort-icon]
            th.sortable(data-col="2") Email #[span.sort-icon]
            th Acciones

        tbody
          if clientes && clientes.length > 0
            each cliente in clientes
              tr
                td= cliente._id
                td= cliente.nombre
                td= cliente.email
                td
                  a.btn.btn-sm.btn-info.me-2(href=`/clientes/${cliente._id}/cuenta-corriente`) Cuenta Corriente
                  a.btn.btn-sm.btn-secondary.me-2(href=`/clientes/${cliente._id}/editar`) Editar
                  if usuarioRol === 'admin'
                    button.btn.btn-sm.btn-danger(onclick=`eliminarCliente('${cliente._id}', this)`) Eliminar
          else
            tr
              td.text-center(colspan="4") No hay clientes en la base de datos.

  script(src="/js/sortTable.js")
  script.
    initSortTable('tablaClientes')
    initSearchTable('tablaClientes', 'buscadorClientes')
    async function eliminarCliente(id, btn) {
      if (!confirm('¿Estás seguro de eliminar este cliente?')) return;
      const res = await fetch(`/clientes/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) {
        alert(data.error);
      } else {
        btn.closest('tr').remove();
      }
    }
