doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        button.btn.btn-primary Nuevo Cliente

      table.table.table-hover.shadow-sm
        thead.table-dark
          tr
            th ID
            th Nombre / Razón Social
            th Email
            th Acciones
        tbody
          each cliente in clientes
            tr
              td= cliente.id
              td= cliente.nombre
              td= cliente.email
              td
                a.btn.btn-sm.btn-info.me-2(href=`/clientes/${cliente.id}/cuenta-corriente`) Cuenta Corriente
                button.btn.btn-sm.btn-warning Editar
          else
            tr
              td.text-center(colspan="4") No hay clientes en la base de datos.