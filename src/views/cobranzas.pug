extends layout

block title
  | Cobranzas

block content
  div.d-flex.justify-content-between.align-items-center.mb-4
    h1.mb-0 Gestión de Cobranzas

  .card.shadow-sm
    .card-header.bg-dark.text-white
      h5.card-title.mb-0 Registro de Cobros Realizados
    .card-body
      .table-responsive
        table.table.table-striped.table-hover.align-middle
          thead
            tr
              th ID
              th Fecha
              th Cliente
              th Descripción
              th Monto Cobrado
          tbody
            if cobranzas && cobranzas.length > 0
              each c in cobranzas
                - let desc = ''
                - if (c.forma_pago === 'efectivo') desc = 'Cobro en efectivo'
                - else if (c.forma_pago === 'transferencia') desc = `Transferencia Nº ${c.nro_comprobante || '-'}`
                - else if (c.forma_pago === 'cheque') desc = `Cheque Nº ${c.nro_comprobante || '-'} · Vto ${c.fecha_vto_cheque ? new Date(c.fecha_vto_cheque).toLocaleDateString('es-AR') : '-'}`
                tr
                  td.text-muted.small= c._id
                  td= new Date(c.fecha).toLocaleDateString('es-AR')
                  td.fw-semibold= c.nombreCliente
                  td= desc
                  td.text-success.fw-bold= `$${c.monto}`
            else
              tr
                td.text-center(colspan="5") No se registraron cobros todavía.