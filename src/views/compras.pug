doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        div.d-flex.gap-2
          a.btn.btn-outline-secondary(href="/")
            i.bi.bi-house-fill.me-1
            | Home
          a.btn.btn-primary(href="/compras/nueva") Registrar Compra

      table.table.table-hover.shadow-sm
        thead.table-dark
          tr
            th Fecha
            th Proveedor (ID)
            th Estado
            th Total
            th Observaciones
            th Acciones
        tbody
          each compra in compras
            tr
              td= new Date(compra.fecha).toLocaleDateString('es-AR')
              td.text-muted.small= compra.proveedor_id
              td
                span.badge(class=compra.estado === 'recibida' ? 'bg-info' : 'bg-secondary')
                  = compra.estado.toUpperCase()
              td.fw-bold= `$${compra.total}`
              td= compra.observaciones || 'Sin observaciones'
              td
                a.btn.btn-sm.btn-outline-secondary(href=`/compras/ver/${compra._id}`) Ver Items
          else
            tr
              td.text-center(colspan="6") No hay compras registradas en el sistema.