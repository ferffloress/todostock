extends layout

block title
  = titulo

block content
  div.d-flex.justify-content-between.align-items-center.mb-4
    h1= titulo
    a.btn.btn-primary(href="/compras/nueva") Registrar Compra

  input.form-control.mb-3#buscadorCompras(type="text", placeholder="Buscar por estado, observaciones...")

  table.table.table-hover.shadow-sm#tablaCompras
    thead.table-dark
      tr
        th.sortable(data-col="0") Fecha #[span.sort-icon]
        th.sortable(data-col="1") Proveedor (ID) #[span.sort-icon]
        th.sortable(data-col="2") Estado #[span.sort-icon]
        th.sortable(data-col="3") Total #[span.sort-icon]
        th Observaciones
        th Acciones
    tbody
      each compra in compras
        tr
          td(data-val=new Date(compra.fecha).getTime())= new Date(compra.fecha).toLocaleDateString('es-AR')
          td.text-muted.small= compra.proveedor_id
          td
            span.badge(class=compra.estado === 'recibida' ? 'bg-info' : 'bg-secondary')
              = compra.estado.toUpperCase()
          td.fw-bold(data-val=compra.total)= `$${compra.total}`
          td= compra.observaciones || 'Sin observaciones'
          td
            a.btn.btn-sm.btn-outline-secondary(href=`/compras/ver/${compra._id}`) Ver Items
      else
        tr
          td.text-center(colspan="6") No hay compras registradas en el sistema.

block scripts
  script(src="/js/sortTable.js")
  script.
    initSortTable('tablaCompras')
    initSearchTable('tablaCompras', 'buscadorCompras')
