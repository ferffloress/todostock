doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

  body.bg-light
    div.container.mt-5.pb-5

      div.d-flex.justify-content-between.align-items-center.mb-4
        h1.fw-bold= titulo
        div.d-flex.gap-2
          a.btn.btn-outline-secondary(href="/")
            i.bi.bi-house-fill.me-1
            | Home
          a.btn.btn-outline-secondary(href="/ventas")
            i.bi.bi-arrow-left.me-1
            | Volver

      div.row.g-4

        //- Tarjeta info general
        div.col-md-6
          div.card.shadow-sm.h-100
            div.card-header.bg-dark.text-white
              h5.mb-0
                i.bi.bi-receipt.me-2
                | Información de la Venta
            div.card-body
              dl.row.mb-0
                dt.col-5 ID
                dd.col-7= `#${venta._id}`
                dt.col-5 Fecha
                dd.col-7= new Date(venta.fecha).toLocaleDateString('es-AR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })
                dt.col-5 Estado
                dd.col-7
                  span.badge.fs-6(class=venta.estado === 'despachada' ? 'bg-success' : (venta.estado === 'cancelada' ? 'bg-danger' : 'bg-warning text-dark'))
                    = venta.estado.toUpperCase()
                dt.col-5 Total
                dd.col-7
                  span.fw-bold.fs-5= `$${venta.total.toLocaleString('es-AR')}`
                if venta.observaciones
                  dt.col-5 Observaciones
                  dd.col-7= venta.observaciones

        //- Tarjeta cliente
        div.col-md-6
          div.card.shadow-sm.h-100
            div.card-header.bg-dark.text-white
              h5.mb-0
                i.bi.bi-person.me-2
                | Cliente
            div.card-body
              if cliente
                dl.row.mb-0
                  dt.col-5 Nombre
                  dd.col-7= cliente.nombre
                  dt.col-5 CUIT
                  dd.col-7= cliente.cuit
                  dt.col-5 Email
                  dd.col-7= cliente.email || '-'
                  dt.col-5 Teléfono
                  dd.col-7= cliente.telefono || '-'
              else
                p.text-muted Cliente no encontrado

      //- Tabla de items
      div.card.shadow-sm.mt-4
        div.card-header.bg-dark.text-white
          h5.mb-0
            i.bi.bi-box-seam.me-2
            | Productos
        div.card-body.p-0
          table.table.table-hover.mb-0
            thead.table-light
              tr
                th Producto
                th Tipo
                th Cant. facturada
                th Cant. unidades
                th Precio unit.
                th Subtotal
            tbody
              each item in items
                tr
                  td= item.nombreProducto
                  td
                    span.badge.bg-secondary= item.tipo_venta || 'unidad'
                  td.text-center= item.cantidad_form !== undefined ? item.cantidad_form : item.cantidad_unidades
                  td.text-center= item.cantidad_unidades
                  td= `$${(item.precio_facturado !== undefined ? item.precio_facturado : (item.precio_unitario || 0)).toLocaleString('es-AR')}`
                  td.fw-bold= `$${item.subtotal.toLocaleString('es-AR')}`
            tfoot.table-light
              tr
                td.text-end.fw-bold(colspan="5") Total
                td.fw-bold.fs-5= `$${venta.total.toLocaleString('es-AR')}`

      //- Acciones (solo si está pendiente)
      if venta.estado === 'pendiente'
        div.d-flex.gap-2.mt-4.justify-content-end
          form(action=`/ventas/despachar/${venta._id}` method="POST")
            button.btn.btn-success(type="submit")
              i.bi.bi-truck.me-1
              | Despachar
          form(action=`/ventas/eliminar/${venta._id}` method="POST" onsubmit="return confirm('¿Cancelar esta venta?')")
            button.btn.btn-danger(type="submit")
              i.bi.bi-x-circle.me-1
              | Cancelar
