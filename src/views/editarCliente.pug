doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

  body.bg-light
    div.container.mt-5
      div.row.justify-content-center
        div.col-md-7
          div.bg-dark.text-white.p-3.d-flex.justify-content-between.align-items-center
            h4.m-0.fw-bold= titulo
            a.btn.btn-outline-light.btn-sm.rounded-0(href="/")
              i.bi.bi-house-fill.me-1
              | Home

          div.bg-white.p-4.border.border-top-0.shadow-sm
            div.mb-3
              label.form-label.fw-bold Nombre / Razón Social
              input.form-control.rounded-0#nombre(type="text", value=cliente.nombre)

            div.row
              div.col-md-6.mb-3
                label.form-label.fw-bold CUIT
                input.form-control.rounded-0#cuit(type="text", value=cliente.cuit)
              div.col-md-6.mb-3
                label.form-label.fw-bold Email
                input.form-control.rounded-0#email(type="email", value=cliente.email)

            div.row
              div.col-md-6.mb-3
                label.form-label.fw-bold Teléfono
                input.form-control.rounded-0#telefono(type="text", value=cliente.telefono)
              div.col-md-6.mb-3
                label.form-label.fw-bold Contacto
                input.form-control.rounded-0#contacto(type="text", value=cliente.contacto)

            div.row
              div.col-md-6.mb-4
                label.form-label.fw-bold Límite de Crédito
                input.form-control.rounded-0#limite_credito(type="number", value=cliente.limite_credito)
              div.col-md-6.mb-4
                label.form-label.fw-bold Saldo Cuenta Corriente
                input.form-control.rounded-0#saldo_cuenta_corriente(type="number", value=cliente.saldo_cuenta_corriente)

            div.d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary.rounded-0(href="/clientes") Cancelar
              button.btn.btn-primary.rounded-0#btnGuardar(type="button") Guardar Cambios

    script.
      document.getElementById('btnGuardar').addEventListener('click', async () => {
        const body = {
          nombre: document.getElementById('nombre').value,
          cuit: document.getElementById('cuit').value,
          email: document.getElementById('email').value,
          telefono: document.getElementById('telefono').value,
          contacto: document.getElementById('contacto').value,
          limite_credito: Number(document.getElementById('limite_credito').value),
          saldo_cuenta_corriente: Number(document.getElementById('saldo_cuenta_corriente').value),
        };
        const res = await fetch(`/clientes/!{cliente.id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) {
          window.location.href = '/clientes';
        } else {
          const data = await res.json();
          alert(data.error);
        }
      });
