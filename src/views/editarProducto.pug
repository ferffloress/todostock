doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")

  body.bg-light
    div.container.mt-5
      div.row.justify-content-center
        div.col-md-7
          div.bg-dark.text-white.p-3.d-flex.justify-content-between.align-items-center
            h4.m-0.fw-bold= titulo
            a.btn.btn-outline-light.btn-sm.rounded-0(href="/")
              i.bi.bi-house-fill.me-1
              | Home

          div.bg-white.p-4.border.border-top-0.shadow-sm
            div.mb-3
              label.form-label.fw-bold Nombre
              input.form-control.rounded-0#nombre(type="text", value=producto.nombre)

            div.row
              div.col-md-6.mb-3
                label.form-label.fw-bold Categoría
                input.form-control.rounded-0#categoria(type="text", value=producto.categoria)
              div.col-md-6.mb-3
                label.form-label.fw-bold Unidad de Medida
                input.form-control.rounded-0#unidad_medida(type="text", value=producto.unidad_medida)

            div.row
              div.col-md-6.mb-3
                label.form-label.fw-bold Precio Costo
                input.form-control.rounded-0#precio_costo(type="number", value=producto.precio_costo)
              div.col-md-6.mb-3
                label.form-label.fw-bold Precio Venta
                input.form-control.rounded-0#precio_venta(type="number", value=producto.precio_venta)

            div.row
              div.col-md-6.mb-4
                label.form-label.fw-bold Stock Actual
                input.form-control.rounded-0#stock_actual(type="number", value=producto.stock_actual)
              div.col-md-6.mb-4
                label.form-label.fw-bold Stock Mínimo
                input.form-control.rounded-0#stock_minimo(type="number", value=producto.stock_minimo)

            div.d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary.rounded-0(href="/productos") Cancelar
              button.btn.btn-primary.rounded-0#btnGuardar(type="button") Guardar Cambios

  script.
    document.getElementById('btnGuardar').addEventListener('click', async () => {
      const body = {
        nombre: document.getElementById('nombre').value,
        categoria: document.getElementById('categoria').value,
        unidad_medida: document.getElementById('unidad_medida').value,
        precio_costo: Number(document.getElementById('precio_costo').value),
        precio_venta: Number(document.getElementById('precio_venta').value),
        stock_actual: Number(document.getElementById('stock_actual').value),
        stock_minimo: Number(document.getElementById('stock_minimo').value),
      };
      const res = await fetch(`/productos/!{producto._id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        window.location.href = '/productos';
      } else {
        const data = await res.json();
        alert(data.error);
      }
    });
