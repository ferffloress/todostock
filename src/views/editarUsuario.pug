doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  body.bg-light
    div.container.mt-5
      div.row.justify-content-center
        div.col-md-7
          div.bg-dark.text-white.p-3.d-flex.justify-content-between.align-items-center
            h4.m-0.fw-bold= titulo
            a.btn.btn-outline-light.btn-sm.rounded-0(href="/usuarios")
              i.bi.bi-arrow-left.me-1
              | Volver
          div.bg-white.p-4.border.border-top-0.shadow-sm
            if error
              .alert.alert-danger= error
            div.mb-3
              label.form-label.fw-bold Nombre
              input.form-control.rounded-0#nombre(type="text" value=usuario.nombre required)
            div.mb-3
              label.form-label.fw-bold Email
              input.form-control.rounded-0#email(type="email" value=usuario.email required)
            div.mb-3
              label.form-label.fw-bold Rol
              select.form-select.rounded-0#rol
                option(value="user" selected=usuario.rol === 'user') user
                option(value="admin" selected=usuario.rol === 'admin') admin
            div.d-flex.justify-content-end.gap-2
              a.btn.btn-outline-secondary.rounded-0(href="/usuarios") Cancelar
              button.btn.btn-primary.rounded-0#btnGuardar(type="button") Guardar Cambios
  script.
    document.getElementById('btnGuardar').addEventListener('click', async () => {
      const body = {
        nombre: document.getElementById('nombre').value,
        email: document.getElementById('email').value,
        rol: document.getElementById('rol').value,
      };
      const res = await fetch(`/usuarios/!{usuario._id}/editar`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        window.location.href = '/usuarios';
      } else {
        const data = await res.json();
        alert(data.error || 'Error al guardar');
      }
    });