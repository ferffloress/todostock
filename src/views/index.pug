doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title TodoStock - Inicio
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  
  body.bg-light
    div.container.mt-5
      div.text-center.mb-5
        h1.fw-bold TodoStock S.A.
    
      
      // Listado módulos
      div.row.justify-content-center
        div.col-md-6
          div.list-group.shadow-sm
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/clientes")
              span Clientes
            
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/productos")
              span Productos
            
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/ventas")
              span Ventas
            
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/compras")
              span Compras
            
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/lotes")
              span Lotes
            
            a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href="/proveedores")
              span Proveedores
            