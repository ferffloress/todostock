doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title TodoStock - Inicio
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  
  body.bg-light
    div.container.mt-5
      div.text-center.mb-5
        h1.fw-bold TodoStock S.A.
    
      
      // Listado módulos
      div.row.justify-content-center
        div.col-md-5.col-lg-4
          div.list-group.shadow-sm.text-center
            a.list-group-item.list-group-item-action(href="/clientes") 
              span Clientes
            
            a.list-group-item.list-group-item-action(href="/productos")
              span Productos
            
            a.list-group-item.list-group-item-action(href="/ventas")
              span Ventas
            
            a.list-group-item.list-group-item-action(href="/compras")
              span Compras
            
            a.list-group-item.list-group-item-action(href="/lotes")
              span Lotes
            
            a.list-group-item.list-group-item-action(href="/proveedores")
              span Proveedores

            a.list-group-item.list-group-item-action(href="/usuarios")
              span Usuarios

            a.btn.btn-danger.fw-bold.mt-3(href="/logout") Cerrar Sesión