mixin navMenu
  nav.nav-menu.nav.flex-column(aria-label="Menu principal")
    each item in menuItems
      - var isActive = item.href === '/' ? currentPath === '/' : currentPath && currentPath.indexOf(item.href) === 0
      a.nav-link(class=isActive ? 'active' : '', href=item.href, aria-current=isActive ? 'page' : false)
        i.bi(class=item.icon, aria-hidden="true")
        span= item.label

doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title
      block title
        | TodoStock
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      :root {
        --sidebar-width: 280px;
        --app-bg: #f3f6f8;
        --app-ink: #17212b;
        --app-muted: #64748b;
        --app-line: #d9e2ea;
        --app-accent: #0f766e;
      }

      body {
        min-height: 100vh;
        background: var(--app-bg);
        color: var(--app-ink);
      }

      .app-shell {
        min-height: 100vh;
      }

      .app-sidebar {
        width: var(--sidebar-width);
        background: #ffffff;
        border-right: 1px solid var(--app-line);
      }

      .brand-mark {
        display: grid;
        width: 42px;
        height: 42px;
        place-items: center;
        border-radius: 8px;
        background: var(--app-accent);
        color: #fff;
        font-weight: 800;
      }

      .nav-menu .nav-link {
        display: flex;
        align-items: center;
        gap: .75rem;
        min-height: 46px;
        margin-bottom: .25rem;
        padding: .7rem .85rem;
        border-radius: 8px;
        color: #334155;
        font-weight: 600;
      }

      .nav-menu .nav-link:hover,
      .nav-menu .nav-link:focus {
        background: #e8f3f1;
        color: #0f766e;
      }

      .nav-menu .nav-link.active {
        background: #0f766e;
        color: #ffffff;
      }

      .app-main {
        flex: 1;
        min-width: 0;
      }

      .mobile-topbar {
        border-bottom: 1px solid var(--app-line);
        background: rgba(255, 255, 255, .96);
        backdrop-filter: blur(10px);
      }

      .dashboard-content {
        max-width: 1320px;
        margin: 0 auto;
        padding: 2rem;
      }

      .page-kicker {
        color: var(--app-muted);
        font-size: .95rem;
      }

      @media (min-width: 992px) {
        .app-sidebar {
          position: sticky;
          top: 0;
          height: 100vh;
          overflow-y: auto;
        }
      }

      @media (max-width: 991.98px) {
        .dashboard-content {
          padding: 1rem;
        }

        .page-title {
          font-size: 1.65rem;
        }
      }

      th.sortable { cursor: pointer; user-select: none; }
      th.sortable:hover { background-color: #343a40; opacity: 0.85; }
      th.sortable .sort-icon { font-size: 0.75rem; margin-left: 4px; opacity: 0.5; }
      th.sortable.asc .sort-icon::after { content: '▲'; opacity: 1; }
      th.sortable.desc .sort-icon::after { content: '▼'; opacity: 1; }
      th.sortable:not(.asc):not(.desc) .sort-icon::after { content: '⇅'; }
    block styles
  body
    - const menuItems = [{href: '/', icon: 'bi-speedometer2', label: 'Dashboard'}, {href: '/clientes', icon: 'bi-people', label: 'Clientes'}, {href: '/productos', icon: 'bi-box-seam', label: 'Productos'}, {href: '/ventas', icon: 'bi-receipt', label: 'Ventas'}, {href: '/compras', icon: 'bi-cart-check', label: 'Compras'}, {href: '/lotes', icon: 'bi-layers', label: 'Lotes'}, {href: '/proveedores', icon: 'bi-truck', label: 'Proveedores'}, {href: '/cobranzas', icon: 'bi-cash-coin', label: 'Cobranzas'}, {href: '/movimientos-stock', icon: 'bi-arrow-left-right', label: 'Movimientos'}, {href: '/alertas', icon: 'bi-bell', label: 'Alertas'}, {href: '/soporte', icon: 'bi-chat-dots', label: 'Soporte'}]
    if usuarioRol === 'admin'
      - menuItems.push({href: '/usuarios', icon: 'bi-person-gear', label: 'Usuarios'})

    div.app-shell.d-lg-flex
      aside.app-sidebar.d-none.d-lg-flex.flex-column.p-4
        div.d-flex.align-items-center.gap-3.mb-4
          div.brand-mark TS
          div
            div.fw-bold TodoStock S.A.
            div.small.text-secondary Gestion comercial
        +navMenu
        div.mt-auto.pt-4
          a.btn.btn-outline-danger.w-100.fw-semibold(href="/logout")
            i.bi.bi-box-arrow-right.me-2(aria-hidden="true")
            | Cerrar sesion

      div.offcanvas.offcanvas-start(id="mobileMenu", tabindex="-1", aria-labelledby="mobileMenuLabel")
        div.offcanvas-header.border-bottom
          div.d-flex.align-items-center.gap-3
            div.brand-mark TS
            div
              h5.offcanvas-title.mb-0(id="mobileMenuLabel") TodoStock S.A.
              div.small.text-secondary Gestion comercial
          button.btn-close(type="button", data-bs-dismiss="offcanvas", aria-label="Cerrar menu")
        div.offcanvas-body.d-flex.flex-column
          +navMenu
          a.btn.btn-outline-danger.w-100.fw-semibold.mt-auto(href="/logout")
            i.bi.bi-box-arrow-right.me-2(aria-hidden="true")
            | Cerrar sesion

      main.app-main
        header.mobile-topbar.sticky-top.d-lg-none
          div.d-flex.align-items-center.justify-content-between.px-3.py-2
            div.d-flex.align-items-center.gap-2
              div.brand-mark TS
              div.fw-bold TodoStock
            button.btn.btn-outline-secondary(type="button", data-bs-toggle="offcanvas", data-bs-target="#mobileMenu", aria-controls="mobileMenu", aria-label="Abrir menu")
              i.bi.bi-list.fs-4(aria-hidden="true")

        div.dashboard-content
          block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    block scripts
