doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    .container.d-flex.justify-content-center.align-items-center.min-vh-100
      .card.shadow-sm(style="max-width: 400px; width: 100%;")
        .card-body.p-4
          h3.text-center.mb-4 TodoStock - Login
          if error
            .alert.alert-danger= error
          if success
            .alert.alert-success= success
          form(action="/login" method="POST")
            .mb-3
              label.form-label Email
              input.form-control(type="email" name="email" required placeholder="tu@email.com")
            .mb-3
              label.form-label Contraseña
              input.form-control(type="password" name="password" required placeholder="Contraseña")
            button.btn.btn-primary.w-100.mt-2(type="submit") Ingresar
          hr.my-3
          p.text-center.mb-0.text-muted ¿No tenés cuenta?
            a.ms-1(href="/registro") Registrate