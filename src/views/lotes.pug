doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      th.sortable { cursor: pointer; user-select: none; }
      th.sortable:hover { background-color: #343a40; opacity: 0.85; }
      th.sortable .sort-icon { font-size: 0.75rem; margin-left: 4px; opacity: 0.5; }
      th.sortable.asc .sort-icon::after { content: '▲'; opacity: 1; }
      th.sortable.desc .sort-icon::after { content: '▼'; opacity: 1; }
      th.sortable:not(.asc):not(.desc) .sort-icon::after { content: '⇅'; }

  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        div.d-flex.gap-2
          a.btn.btn-outline-secondary(href="/")
            i.bi.bi-house-fill.me-1
            | Home
          a.btn.btn-primary(href="/lotes/nuevo") Nuevo Lote

      table.table.table-hover.shadow-sm#tablaLotes
        thead.table-dark
          tr
            th.sortable(data-col="0") Número de Lote #[span.sort-icon]
            th.sortable(data-col="1") Producto #[span.sort-icon]
            th.sortable(data-col="2") Cant. Actual #[span.sort-icon]
            th.sortable(data-col="3") Costo Unit. #[span.sort-icon]
            th.sortable(data-col="4") Vencimiento #[span.sort-icon]
            th Acciones
        tbody
          each lote in lotes
            tr
              td.fw-bold= lote.numero_lote
              td= lote.nombreProducto
              td(data-val=lote.cantidad_actual)= lote.cantidad_actual
              td(data-val=lote.costo_unitario)= `$${lote.costo_unitario}`
              td(data-val=new Date(lote.fecha_vencimiento).getTime())
                - const fechaVenc = new Date(lote.fecha_vencimiento)
                - const sinVenc = fechaVenc.getFullYear() >= 2099
                span(class=!sinVenc && fechaVenc < new Date() ? 'text-danger fw-bold' : '')
                  = sinVenc ? 'Sin vencimiento' : fechaVenc.toLocaleDateString('es-AR')
              td
                div.d-flex.gap-1
                  a.btn.btn-sm.btn-secondary.me-1(href=`/lotes/${lote._id}/movimientos`) Ver Movimientos
                  a.btn.btn-sm.btn-secondary.me-1(href=`/lotes/${lote._id}/editar`) Editar
                  form(method="POST", action=`/lotes/${lote._id}/eliminar`, style="display:inline", onsubmit="return confirm('¿Seguro que querés eliminar este lote?')")
                    button.btn.btn-sm.btn-danger(type="submit") Eliminar
          else
            tr
              td.text-center(colspan="6") No hay lotes registrados en el inventario.

    script.
        let sortCol = -1;
        let sortAsc = true;

        document.querySelectorAll('th.sortable').forEach(th => {
          th.addEventListener('click', () => {
            const col = Number(th.dataset.col);
            if (sortCol === col) {
              sortAsc = !sortAsc;
            } else {
              sortCol = col;
              sortAsc = true;
            }

            document.querySelectorAll('th.sortable').forEach(h => h.classList.remove('asc', 'desc'));
            th.classList.add(sortAsc ? 'asc' : 'desc');

            const tbody = document.querySelector('#tablaLotes tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
              const cellA = a.cells[col];
              const cellB = b.cells[col];
              const valA = cellA.dataset.val !== undefined ? Number(cellA.dataset.val) : cellA.textContent.trim().toLowerCase();
              const valB = cellB.dataset.val !== undefined ? Number(cellB.dataset.val) : cellB.textContent.trim().toLowerCase();

              if (valA < valB) return sortAsc ? -1 : 1;
              if (valA > valB) return sortAsc ? 1 : -1;
              return 0;
            });

            rows.forEach(r => tbody.appendChild(r));
          });
        });        