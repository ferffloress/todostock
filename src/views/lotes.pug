doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        div.d-flex.gap-2
          a.btn.btn-outline-secondary(href="/")
            i.bi.bi-house-fill.me-1
            | Home
          a.btn.btn-primary(href="/lotes/nuevo") Nuevo Lote

      table.table.table-hover.shadow-sm
        thead.table-dark
          tr
            th Número de Lote
            th Producto (ID)
            th Cant. Actual
            th Costo Unit.
            th Vencimiento
            th Acciones
        tbody
          each lote in lotes
            tr
              td.fw-bold= lote.numero_lote
              td.text-muted.small= lote.producto_id
              td= lote.cantidad_actual
              td= `$${lote.costo_unitario}`
              td
                //- Formateamos la fecha de vencimiento del JSON
                span(class=new Date(lote.fecha_vencimiento) < new Date() ? 'text-danger fw-bold' : '')
                  = new Date(lote.fecha_vencimiento).toLocaleDateString('es-AR')
              td
                button.btn.btn-sm.btn-outline-secondary Ver Movimientos
          else
            tr
              td.text-center(colspan="6") No hay lotes registrados en el inventario.