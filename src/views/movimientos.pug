extends layout

block title
  | Movimientos

block content
  div.d-flex.flex-column.flex-sm-row.justify-content-between.align-items-start.align-items-sm-center.gap-3.mb-4
    h1.mb-0 Historial de Movimientos

  input.form-control.mb-3#buscadorMovimientos(type="text", placeholder="Buscar por tipo, producto, descripción...")
  
  .card.shadow-sm
    .card-header.bg-dark.text-white
      h5.card-title.mb-0 Registro de Auditoría General
    .card-body
      .table-responsive
        table.table.table-striped.table-hover.align-middle#tablaMovimientos
          thead
            tr
              th Fecha
              th Tipo
              th Producto ID
              th Cantidad
              th Descripción
          tbody
            if movimientos && movimientos.length > 0
              each m in movimientos
                tr
                  td= m.fecha ? m.fecha.toLocaleDateString('es-AR') : 'Sin fecha'
                  td
                    span.badge(class=m.tipo === 'egreso' || m.tipo === 'Egreso' ? 'bg-danger' : 'bg-success')= m.tipo
                  td= m.producto_id
                  td.fw-bold= m.cantidad
                  td= m.descripcion || 'Movimiento de stock registrado'
            else
              tr
                td.text-center(colspan="5") No se registraron movimientos recientes.

block scripts
  script(src="/js/sortTable.js")
  script.
    initSearchTable('tablaMovimientos', 'buscadorMovimientos')
    