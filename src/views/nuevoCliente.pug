extends layout

block title
  = titulo

block content
  div.row.justify-content-center
    div.col-md-7
      div.bg-dark.text-white.p-3
        h4.m-0.fw-bold= titulo

      div.bg-white.p-4.border.border-top-0.shadow-sm
        if errores && errores.length
          div.alert.alert-danger.rounded-0
            ul.mb-0
              each e in errores
                li= e
        form(method="POST", action="/clientes")
          div.mb-3
            label.form-label.fw-bold Nombre / Razón Social
            input.form-control.rounded-0(type="text", name="nombre")

          div.row
            div.col-md-6.mb-3
              label.form-label.fw-bold CUIT
              input.form-control.rounded-0#cuit(type="text", name="cuit", placeholder="XX-XXXXXXXX-X", maxlength="13")
              small.text-muted Se agregan los guiones automáticamente
            div.col-md-6.mb-3
              label.form-label.fw-bold Email
              input.form-control.rounded-0(type="email", name="email")

          div.row
            div.col-md-6.mb-3
              label.form-label.fw-bold Teléfono
              input.form-control.rounded-0#telefono(type="text", name="telefono", placeholder="Solo números")
            div.col-md-6.mb-3
              label.form-label.fw-bold Contacto
              input.form-control.rounded-0(type="text", name="contacto")

          div.row
            div.col-md-6.mb-4
              label.form-label.fw-bold Límite de Crédito
              input.form-control.rounded-0(type="number", min="0", name="limite_credito", value="0")
            div.col-md-6.mb-4
              label.form-label.fw-bold Saldo Inicial
              input.form-control.rounded-0(type="number", min="0", name="saldo_cuenta_corriente", value="0")

          div.d-flex.justify-content-end.gap-2
            a.btn.btn-outline-secondary.rounded-0(href="/clientes") Cancelar
            button.btn.btn-primary.rounded-0(type="submit") Guardar Cliente

block scripts
  script.
    const cuitInput = document.getElementById('cuit');
    cuitInput.addEventListener('input', function () {
      let val = this.value.replace(/\D/g, '');
      if (val.length > 2)  val = val.slice(0,2) + '-' + val.slice(2);
      if (val.length > 11) val = val.slice(0,11) + '-' + val.slice(11);
      this.value = val.slice(0, 13);
    });

    const telInput = document.getElementById('telefono');
    telInput.addEventListener('input', function () {
      this.value = this.value.replace(/\D/g, '');
    });
