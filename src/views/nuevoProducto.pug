doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
  
  body.bg-light
    div.container.mt-5
      div.row.justify-content-center
        div.col-md-7
          div.bg-dark.text-white.p-3.d-flex.justify-content-between.align-items-center
            h4.m-0.fw-bold= titulo
            a.btn.btn-outline-light.btn-sm.rounded-0(href="/")
              i.bi.bi-house-fill.me-1
              | Home
          
          div.bg-white.p-4.border.border-top-0.shadow-sm
            form(method="POST", action="/productos")
              div.mb-3
                label.form-label.fw-bold Nombre
                input.form-control.rounded-0(type="text", name="nombre")

              div.row
                div.col-md-6.mb-3
                  label.form-label.fw-bold Categoría
                  input.form-control.rounded-0(type="text", name="categoria")
                div.col-md-6.mb-3
                  label.form-label.fw-bold Unidad de Medida
                  input.form-control.rounded-0(type="text", name="unidad_medida")

              div.row
                div.col-md-6.mb-3
                  label.form-label.fw-bold Precio Costo
                  input.form-control.rounded-0(type="number", name="precio_costo", value="0")
                div.col-md-6.mb-3
                  label.form-label.fw-bold Precio Venta
                  input.form-control.rounded-0(type="number", name="precio_venta", value="0")

              div.row
                div.col-md-4.mb-4
                  label.form-label.fw-bold Stock Actual
                  input.form-control.rounded-0(type="number", name="stock_actual", value="0")
                div.col-md-4.mb-4
                  label.form-label.fw-bold Stock Mínimo
                  input.form-control.rounded-0(type="number", name="stock_minimo", value="0")
                div.col-md-4.mb-4
                  label.form-label.fw-bold Unidades por Bulto
                  input.form-control.rounded-0(type="number", name="unidades_por_bulto", value="1", min="1")

              div.d-flex.justify-content-end.gap-2
                a.btn.btn-outline-secondary.rounded-0(href="/productos") Cancelar
                button.btn.btn-primary.rounded-0(type="submit") Guardar Producto