doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        a.btn.btn-primary(href="/productos/nuevo-producto") Nuevo Producto

      table.table.table-hover.shadow-sm
        thead.table-dark
          tr
            th Nombre
            th Categoría
            th Precio Costo
            th Precio Venta
            th Stock
            th Unidad
            th Acciones
        tbody
          each producto in productos
            tr
              td= producto.nombre
              td= producto.categoria
              td= `$${producto.precio_costo}`
              td= `$${producto.precio_venta}`
              td
                span(class=producto.stock_actual <= producto.stock_minimo ? 'text-danger fw-bold' : '')
                  = producto.stock_actual
              td= producto.unidad_medida
              td
                button.btn.btn-sm.btn-secondary.me-1 Editar
                button.btn.btn-sm.btn-danger(onclick=`eliminarProducto('${producto.id}', this)`) Eliminar
          else
            tr
              td.text-center(colspan="7") No hay productos en la base de datos.

    script.
      async function eliminarProducto(id, btn) {
        const res = await fetch(`/productos/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (!res.ok) {
          alert(data.error);
        } else {
          btn.closest('tr').remove();
        }
      }