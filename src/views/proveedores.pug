doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    div.container.mt-5
      div.d-flex.justify-content-between.align-items-center.mb-4
        h1= titulo
        a.btn.btn-primary(href="/proveedores/nuevo") Nuevo Proveedor

      table.table.table-hover.shadow-sm
        thead.table-dark
          tr
            th Nombre
            th CUIT
            th Contacto
            th Teléfono
            th Email
            th Pago
            th Acciones
        tbody
          each prov in proveedores
            tr
              td.fw-bold= prov.nombre
              td= prov.cuit
              td= prov.contacto
              td= prov.telefono
              td
                a(href=`mailto:${prov.email}`)= prov.email
              td: span.badge.bg-secondary= prov.condicion_pago
              td
                button.btn.btn-sm.btn-outline-secondary.me-1 Editar
                button.btn.btn-sm.btn-danger(onclick=`eliminarProveedor('${prov.id}', this)`) Eliminar
          else
            tr
              td.text-center(colspan="7") No hay proveedores registrados.

    script.
      async function eliminarProveedor(id, btn) {
        const res = await fetch(`/proveedores/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (!res.ok) {
          alert(data.error);
        } else {
          btn.closest('tr').remove();
        }
      }
