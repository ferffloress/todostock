doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    .container.d-flex.justify-content-center.align-items-center.min-vh-100
      .card.shadow-sm(style="max-width: 400px; width: 100%;")
        .card-body.p-4
          h3.text-center.mb-4 TodoStock - Crear cuenta
          if error
            .alert.alert-danger= error
          form(action="/registro" method="POST")
            .mb-3
              label.form-label Nombre
              input.form-control(type="text" name="nombre" required placeholder="Tu nombre")
            .mb-3
              label.form-label Email
              input.form-control(type="email" name="email" required placeholder="tu@email.com")
            .mb-3
              label.form-label Contraseña
              input.form-control(type="password" name="password" required placeholder="Mínimo 6 caracteres")
            .mb-3
              label.form-label Confirmar contraseña
              input.form-control(type="password" name="confirmarPassword" required placeholder="Repetí la contraseña")
            button.btn.btn-success.w-100.mt-2(type="submit") Crear cuenta
          hr.my-3
          p.text-center.mb-0.text-muted ¿Ya tenés cuenta?
            a.ms-1(href="/login") Iniciá sesión