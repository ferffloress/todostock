doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css")
    style.
      th.sortable { cursor: pointer; user-select: none; }
      th.sortable:hover { background-color: #343a40; opacity: 0.85; }
      th.sortable .sort-icon { font-size: 0.75rem; margin-left: 4px; opacity: 0.5; }
      th.sortable.asc .sort-icon::after { content: '▲'; opacity: 1; }
      th.sortable.desc .sort-icon::after { content: '▼'; opacity: 1; }
      th.sortable:not(.asc):not(.desc) .sort-icon::after { content: '⇅'; }
  body
    .container.mt-4
      h2 Administrar usuarios
      a.btn.btn-secondary.mb-3(href="/") Volver
      table.table.table-bordered.table-hover.align-middle#tablaUsuarios
        thead.table-dark
          tr
            th.sortable(data-col="0") Nombre #[span.sort-icon]
            th.sortable(data-col="1") Email #[span.sort-icon]
            th.sortable(data-col="2") Rol #[span.sort-icon]
            th Cambiar rol
            th Editar
            th Eliminar
        tbody
          each u in usuarios
            tr
              td= u.nombre
              td= u.email
              td
                if u.rol === 'admin'
                  span.badge.bg-danger admin
                else
                  span.badge.bg-secondary user
              td
                form(action=`/usuarios/${u._id}/rol` method="POST")
                  if u.rol === 'admin'
                    button.btn.btn-sm.btn-outline-secondary(type="submit") Quitar admin
                  else
                    button.btn.btn-sm.btn-outline-danger(type="submit") Hacer admin
              td
                a.btn.btn-sm.btn-outline-primary(href=`/usuarios/${u._id}/editar`) Editar
              td
                form(action=`/usuarios/${u._id}/eliminar` method="POST" onsubmit="return confirm('¿Seguro que querés eliminar este usuario?')")
                  button.btn.btn-sm.btn-danger(type="submit") Eliminar

    script(src="/js/sortTable.js")
    script.
      initSortTable('tablaUsuarios')                  