doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= titulo
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-4
      h2 Administrar usuarios
      a.btn.btn-secondary.mb-3(href="/") Volver
      table.table.table-bordered.table-hover.align-middle
        thead.table-dark
          tr
            th Nombre
            th Email
            th Rol
            th Cambiar rol
            th Editar
            th Eliminar
        tbody
          each u in usuarios
            tr
              td= u.nombre
              td= u.email
              td
                if u.rol === 'admin'
                  span.badge.bg-danger admin
                else
                  span.badge.bg-secondary user
              td
                form(action=`/usuarios/${u._id}/rol` method="POST")
                  if u.rol === 'admin'
                    button.btn.btn-sm.btn-outline-secondary(type="submit") Quitar admin
                  else
                    button.btn.btn-sm.btn-outline-danger(type="submit") Hacer admin
              td
                a.btn.btn-sm.btn-outline-primary(href=`/usuarios/${u._id}/editar`) Editar
              td
                form(action=`/usuarios/${u._id}/eliminar` method="POST" onsubmit="return confirm('¿Seguro que querés eliminar este usuario?')")
                  button.btn.btn-sm.btn-danger(type="submit") Eliminar