extends layout

block title
  = titulo

block content
  div.d-flex.justify-content-between.align-items-center.mb-4
    h1= titulo
    a.btn.btn-primary(href="/ventas/nueva-venta") Nueva Venta

  input.form-control.mb-3#buscadorVentas(type="text", placeholder="Buscar por cliente, estado...")

  table.table.table-hover.shadow-sm#tablaVentas
    thead.table-dark
      tr
        th.sortable(data-col="0") ID Venta #[span.sort-icon]
        th.sortable(data-col="1") Cliente #[span.sort-icon]
        th.sortable(data-col="2") Fecha #[span.sort-icon]
        th.sortable(data-col="3") Estado #[span.sort-icon]
        th.sortable(data-col="4") Total #[span.sort-icon]
        th Acciones
    tbody
      each venta in ventas
        tr
          td.text-muted.small= venta._id
          td= venta.nombreCliente
          td(data-val=new Date(venta.fecha).getTime())= new Date(venta.fecha).toLocaleDateString('es-AR')
          td
            span.badge(class=venta.estado === 'despachada' ? 'bg-success' : (venta.estado === 'cancelada' ? 'bg-danger' : 'bg-warning'))
              = venta.estado.toUpperCase()
          td.fw-bold(data-val=venta.total)= `$${venta.total}`
          td.d-flex.gap-1
            a.btn.btn-sm.btn-secondary(href=`/ventas/ver/${venta._id}`) Detalle

            if venta.estado === 'pendiente'
              form(action=`/ventas/despachar/${venta._id}` method="POST")
                button.btn.btn-sm.btn-success(type="submit") Despachar

            if venta.estado === 'pendiente'  && usuarioRol === 'admin'
              form(action=`/ventas/eliminar/${venta._id}` method="POST" onsubmit="return confirm('¿Está seguro de cancelar esta venta?')")
                button.btn.btn-sm.btn-danger(type="submit") Eliminar
      else
        tr
          td.text-center(colspan="6") No hay ventas registradas.

block scripts
  script(src="/js/sortTable.js")
  script.
    initSortTable('tablaVentas')
    initSearchTable('tablaVentas', 'buscadorVentas')
